{
  "name": "maverics-site",
  "description": "Maverics.ai - The runtime identity control plane for AI Agents",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.15.0"
  },
  "scripts": {
    "clean": "gatsby clean",
    "start": "npm run develop",
    "build": "npm run clean && mkdir -p .cache && gatsby build",
    "develop": "npm run clean && mkdir -p .cache && gatsby develop",
    "develop:fast": "gatsby develop",
    "cms": "npx decap-server",
    "serve": "gatsby serve",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "decap-cms-app": "^3.3.3",
    "gatsby": "^4.25.0",
    "gatsby-plugin-decap-cms": "^4.0.0",
    "gatsby-plugin-image": "^2.25.0",
    "gatsby-plugin-netlify": "^5.1.0",
    "gatsby-plugin-react-helmet": "^5.25.0",
    "gatsby-plugin-sass": "^5.25.0",
    "gatsby-plugin-sharp": "^4.25.0",
    "gatsby-remark-copy-linked-files": "^5.25.0",
    "gatsby-remark-images": "^6.25.0",
    "gatsby-remark-prismjs": "^6.25.0",
    "gatsby-source-filesystem": "^4.25.0",
    "gatsby-transformer-remark": "^5.25.0",
    "gatsby-transformer-sharp": "^4.25.0",
    "lodash": "^4.17.21",
    "prismjs": "^1.29.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-slick": "^0.30.0",
    "sass": "^1.69.0",
    "slick-carousel": "^1.8.1",
    "zod": "^4.3.6"
